# Python ML Service (ml_service/)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto          # auto | cpu | cuda
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CHROMA_COLLECTION=documents
ML_HOST=0.0.0.0
ML_PORT=8001

# .NET API — configure in OpenRAG.Api/appsettings.json or via env overrides:
# MlService__BaseUrl=http://localhost:8001
# ConnectionStrings__Default=Data Source=../data/openrag.db

# LLM (optional — enables RAG answer generation and multi-turn Q&A)
# Uses OpenAI-compatible API. Set via appsettings.json or env overrides:
# Llm__BaseUrl=https://api.openai.com/v1
# Llm__ApiKey=sk-...
# Llm__Model=gpt-4o-mini

# BM25 Tantivy index
# BM25_WRITER_HEAP_SIZE=50000000
