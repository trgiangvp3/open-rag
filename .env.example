# Embedding model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=auto          # auto | cpu | cuda

# ChromaDB
CHROMA_COLLECTION=documents

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Search
DEFAULT_TOP_K=5

# Markitdown service (for file conversion)
MARKITDOWN_URL=http://localhost:5000

# Server
HOST=0.0.0.0
PORT=8000
