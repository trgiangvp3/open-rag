<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <PublishProvider>IISWebDeploy</PublishProvider>

    <!-- Server Web Deploy -->
    <MSDeployServiceURL>https://deploy.giatocnguyenhuu.vn:12178/msdeploy.axd</MSDeployServiceURL>
    <DeployIisAppPath>OpenRag</DeployIisAppPath>
    <UserName>INSTANCE-078585\Administrator</UserName>

    <!-- Build config -->
    <Configuration>Release</Configuration>
    <TargetFramework>net8.0</TargetFramework>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <!-- Deploy options -->
    <AllowUntrustedCertificate>true</AllowUntrustedCertificate>
    <SkipExtraFilesOnServer>true</SkipExtraFilesOnServer>
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>

    <!-- Environment -->
    <EnvironmentName>Production</EnvironmentName>
  </PropertyGroup>

  <!--
    Skip rules: Web Deploy KHÔNG xoá các thư mục này trên server.
    Tất cả nằm chung trong C:\OpenRAG (= IIS site physical path).
  -->
  <ItemGroup>
    <!-- Dữ liệu -->
    <MsDeploySkipRules Include="SkipAppData">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\AppData</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipLogs">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\logs</AbsolutePath>
    </MsDeploySkipRules>

    <!-- Python / ML -->
    <MsDeploySkipRules Include="SkipMlService">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\ml_service</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipModels">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\models</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipPython">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\python312</AbsolutePath>
    </MsDeploySkipRules>

    <!-- Tools -->
    <MsDeploySkipRules Include="SkipNssm">
      <SkipAction>Delete</SkipAction>
      <ObjectName>dirPath</ObjectName>
      <AbsolutePath>\\nssm</AbsolutePath>
    </MsDeploySkipRules>

    <!-- Config -->
    <MsDeploySkipRules Include="SkipEnv">
      <SkipAction>Delete</SkipAction>
      <ObjectName>filePath</ObjectName>
      <AbsolutePath>\\.env</AbsolutePath>
    </MsDeploySkipRules>
    <MsDeploySkipRules Include="SkipDb">
      <SkipAction>Delete</SkipAction>
      <ObjectName>filePath</ObjectName>
      <AbsolutePath>openrag\.db</AbsolutePath>
    </MsDeploySkipRules>
  </ItemGroup>
</Project>
